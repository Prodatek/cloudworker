APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://cloudworker:cloudworker@db:5432/cloudworker
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT_SECONDS=5

# Worker provisioning (Phase 4) — leave blank until infra/terraform/environments/dev has
# actually been applied to a real AWS account; the API/worker both run fine without these
# set (worker provisioning-dependent features return 503 / the worker process idles).
AWS_REGION=us-east-1
LAUNCH_TEMPLATE_ID=
WORKER_SUBNET_IDS=
SSM_READY_TIMEOUT_SECONDS=120
WORKER_POLL_INTERVAL_SECONDS=5

# Job execution (Phase 5/6) — logs/artifacts buckets from Phase 3's storage module outputs.
LOGS_BUCKET_NAME=
ARTIFACTS_BUCKET_NAME=
JOB_EXECUTION_TIMEOUT_SECONDS=900
MAX_CONCURRENT_JOBS=5
ARTIFACT_URL_EXPIRY_SECONDS=900

# Dashboard auth (Phase 7). SECURITY: JWT_SECRET_KEY MUST be overridden with a real secret
# for any deployment beyond a laptop — the default is intentionally insecure.
JWT_SECRET_KEY=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
CORS_ALLOWED_ORIGINS=http://localhost:5173
